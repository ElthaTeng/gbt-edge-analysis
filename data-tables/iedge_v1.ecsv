# %ECSV 1.0
# ---
# datatype:
# - {name: CALIFA_name, datatype: string, description: Name of the galaxy as indicated in the CALIFA extended DR3}
# - {name: Alias, datatype: string, description: Alternative name of the galaxy}
# - {name: RA, unit: deg, datatype: float64, description: Right ascension of the galaxy centre}
# - {name: DEC, unit: deg, datatype: float64, description: Declination of the galaxy centre}
# - {name: Vlsr, unit: km / s, datatype: float64, description: 'LSR velocity of the galaxy, derived from the stellar redshift'}
# - {name: zstar, datatype: float64, description: Stellar redshift of the galaxy}
# - {name: Distance, unit: Mpc, datatype: float64, description: Distance to the galaxy}
# - {name: Incl, unit: deg, datatype: float64, description: Galaxy inclination}
# - {name: PA, unit: deg, datatype: float64, description: Galaxy position angle}
# - {name: Re_as, unit: arcsec, datatype: float64, description: Galaxy effective radius}
# - {name: Glob_med_EWHa, unit: Angstrom, datatype: float64, description: Global median Halpha equivalent width}
# - {name: Glob_Mstar, unit: solMass, datatype: float64, description: Global stellar mass}
# - {name: Glob_SFR, unit: solMass / yr, datatype: float64, description: Global star formation rate derived using Balmer decrement}
# - {name: Glob_sSFR, unit: 1 / yr, datatype: float64, description: Global specific star formation rate}
# - {name: Err_Glob_Mstar, unit: solMass, datatype: float64, description: Global uncertainty on the stellar mass}
# - {name: Err_Glob_SFR, unit: solMass / yr, datatype: float64, description: Global uncertainty on the star formation rate derived using
#     Balmer decrement}
# - {name: Err_Glob_sSFR, unit: 1 / yr, datatype: float64, description: Global uncertainty on the specific star formation rate}
# - {name: Glob_Gas_Met, datatype: float64, description: Global gas-phase metallicity derived via the O3N2 method}
# - {name: Glob_alpha_co10_b13, unit: s solMass / (K km pc2), datatype: float64, description: Global CO(1-0)-to-H2 conversion factor derived
#     following Bolatto et al. (2013)}
# - {name: Glob_R21, datatype: float64, description: Global CO(2-1)/CO(1-0) flux ratio derived from the star formation rate surface density}
# - {name: APEX_Glob_k2jypb, unit: Jy / K, datatype: float64, description: APEX Global Jy/beam per Kelvin}
# - {name: APEX_Glob_eta_mb, datatype: float64, description: APEX Global main beam efficiency}
